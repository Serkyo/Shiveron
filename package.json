{
	"name": "shiveron",
	"version": "1.2.0",
	"description": "Modular and multipurpose Discord Bot, built using discord.js v14",
	"main": "dist/bot.js",
	"scripts": {
		"start": "npm run build && node .",
		"build": "node -e \"const fs=require('fs'); fs.rmSync('./dist', {recursive:true, force:true})\" && tsc && node -e \"const fs=require('fs'); fs.cpSync('./src/locales', './dist/locales', {recursive: true})\"",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"keywords": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Serkyo/Shiveron.git"
	},
	"author": "Serkyo",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/Serkyo/Shiveron/issues"
	},
	"homepage": "https://github.com/Serkyo/Shiveron#readme",
	"type": "module",
	"dependencies": {
		"async-lock": "^1.4.1",
		"discord.js": "^14.25.1",
		"pg": "^8.21.0",
		"sequelize": "^6.37.7"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/async-lock": "^1.4.2",
		"@types/node": "^25.9.0",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "10.1.8",
		"jiti": "^2.7.0",
		"prettier": "3.8.3",
		"typescript": "^6.0.3"
	}
}
